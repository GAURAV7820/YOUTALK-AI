{
  "manifest_version": 3,
  "name": "YouTalk AI",
  "version": "1.0",
  "description": "AI YouTube Doubt Assistant",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}