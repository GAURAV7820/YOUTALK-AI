{
  "manifest_version": 3,
  "name": "YouTalk AI",
  "version": "1.0",
  "description": "AI YouTube Doubt Assistant",
 "permissions": ["tabs", "scripting"],
"host_permissions": [
  "http://localhost:3000/*"
],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}